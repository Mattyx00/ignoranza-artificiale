# =============================================================================
# SVILUPPO LOCALE (docker-compose)
# =============================================================================

# DATABASE_URL — injected by docker-compose via the `db` service.
# Format: postgresql+asyncpg://user:password@host:port/dbname
# Do NOT set this manually for local development — docker-compose handles it.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/ignoranza

# DB_SSL_REQUIRE — keep false locally (no TLS on the docker-compose Postgres).
DB_SSL_REQUIRE=false

# REDIS_URL — injected by docker-compose via the `redis` service.
REDIS_URL=redis://redis:6379/0

# OpenRouter API key — get yours at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# CORS — allow the local Next.js dev server.
CORS_ORIGINS=["http://localhost:3000"]

# Security headers — disable HTTPS redirect locally.
HTTPS_ENABLED=false

# Reverse-proxy trust — set to true ONLY when behind a trusted proxy (Nginx,
# Traefik, AWS ALB, DO Load Balancer) that is the sole public entry point AND
# that strips/overwrites client-supplied X-Forwarded-For headers.
# Keeping this false prevents rate-limit bypass via XFF header spoofing.
TRUST_PROXY=false

# Trusted hosts — must be non-empty or TrustedHostMiddleware rejects everything.
ALLOWED_HOSTS=localhost,127.0.0.1

# OpenAPI/Swagger docs — enable in development only.
DOCS_ENABLED=true


# =============================================================================
# PRODUZIONE (DigitalOcean App Platform)
# Copy the block below into the App Platform "Environment Variables" UI or
# into a separate .env file that is NOT committed to the repository.
# =============================================================================

# DATABASE_URL — provided by DO Managed Postgres ("Connection String" field).
# DO already embeds the correct host/port/credentials; paste it as-is.
# Port 25060 is the Managed Postgres TLS-only port.
# Format: postgresql+asyncpg://user:password@host:25060/dbname
# DATABASE_URL=postgresql+asyncpg://doadmin:password@db-host.db.ondigitalocean.com:25060/defaultdb

# DB_SSL_REQUIRE — MUST be true for DO Managed Postgres.
# asyncpg requires ssl=True in connect_args, not ?sslmode=require in the URL.
# DB_SSL_REQUIRE=true

# REDIS_URL — private URL of the Redis service on App Platform.
# Use the internal private URL (not the public one) to keep traffic within DO's network.
# REDIS_URL=redis://private-redis-host:25061/0

# OpenRouter API key
# OPENROUTER_API_KEY=your_openrouter_api_key_here

# CORS — set to the public domain of your DO App Platform frontend component.
# CORS_ORIGINS=["https://your-app.ondigitalocean.app"]

# Security headers — enable HTTPS redirect in production.
# HTTPS_ENABLED=true

# Trusted hosts — set to the backend component's public domain.
# ALLOWED_HOSTS=your-backend.ondigitalocean.app

# OpenAPI/Swagger docs — keep disabled in production.
# DOCS_ENABLED=false
